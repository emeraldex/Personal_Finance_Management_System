<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>

<GridPane fx:id="historyScreen" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.expensedesktop.controller.HistoryController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <Label text="Expenses" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
    <Label fx:id="expensesLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
    <Label text="Incomes" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <Label fx:id="incomesLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    <Button text="Refresh" GridPane.columnIndex="1" GridPane.rowIndex="2" onAction="#refreshHistory"/>
</GridPane>
